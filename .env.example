# Environment Variables Template
# Copy this file to .env.local and fill in the values

# Application Settings
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Classical Virtues"

# Analytics (Optional)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=

# Database (if needed in future)
# DATABASE_URL=

# External Services (if needed)
# API_KEY=

# Basehub CMS
# Both come from the Basehub project dashboard (Settings → Read tokens / Webhooks).
# Leave empty for local work: the app degrades gracefully (empty story list / null story).
BASEHUB_TOKEN=
BASEHUB_WEBHOOK_SECRET=

# Development Settings
# Note: do NOT set NODE_ENV here — Next.js manages it automatically and warns
# when it is set manually. It is intentionally omitted.
NEXT_TELEMETRY_DISABLED=1
